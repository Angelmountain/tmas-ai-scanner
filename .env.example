# Trend Micro Vision One
TMAS_API_KEY=your-vision-one-api-key-here
TMAS_REGION=eu-central-1

# LLM Endpoint
LLM_ENDPOINT=https://api.openai.com/v1
LLM_API_KEY=sk-your-openai-key-here
LLM_MODEL=gpt-4
# TMAS reads the key from this env var name (set in config as api_key_env)
LLM_API_KEY_ENV=LLM_API_KEY

# Scan Settings
ATTACK_PRESET=owasp
