# Vision One API (for security assessment searches)
TREND_MICRO_API_KEY=your-vision-one-api-key-here
TREND_MICRO_BASE_URL=https://api.eu.xdr.trendmicro.com

# TMAS AI Scanner (for LLM security testing)
TMAS_API_KEY=your-vision-one-api-key-here
TMAS_REGION=eu-central-1

# LLM Provider (for AI scan)
LLM_ENDPOINT=https://api.openai.com/v1
LLM_API_KEY=sk-your-openai-key-here
LLM_MODEL=gpt-4

# Web Server
PORT=3000
HTTPS_PORT=3443
NODE_ENV=production
